# Copy this file to .env.local and fill in your actual credentials
# NEVER commit .env.local to git

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>

# Google OAuth — get these from https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Owner/Admin Credentials
NEXT_PUBLIC_OWNER_EMAIL=
NEXT_PUBLIC_OWNER_PASSWORD=
NEXT_PUBLIC_OWNER_NAME=